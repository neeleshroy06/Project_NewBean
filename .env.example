# Copy to .env and fill in your keys
PORT=3000

# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Required speech-to-text provider
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Optional: Vultr API (competition / connectivity check — GET /api/vultr-ping)
# https://www.vultr.com/api/#tag/account
# VULTR_API_KEY=your_vultr_personal_access_token

# Optional overrides
# ELEVENLABS_MODEL_ID=scribe_v2
# ElevenLabs transcribes the mic audio, then Gemini turns the transcript into cart actions.
# GEMINI_MODEL=gemini-2.5-flash
